{
  "name": "n8n-nodes-prodex",
  "version": "0.7.1",
  "description": "Self-hosted n8n ProDex node via ChatGPT subscription device-code auth",
  "license": "MIT",
  "homepage": "https://prodex.proday.in",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "codex",
    "prodex",
    "openai",
    "ai-agent",
    "chat-model",
    "langchain",
    "self-hosted"
  ],
  "author": {
    "name": "Nils",
    "email": "collegeitpro@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artNcraft/n8n-nodes-prodex.git"
  },
  "bin": {
    "n8n-nodes-prodex": "./scripts/device-code-bootstrap.mjs",
    "prodex-login": "./scripts/device-code-bootstrap.mjs",
    "n8n-data-tables": "./scripts/n8n-data-tables.mjs"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "prepublishOnly": "npm run build && npm test",
    "publish:public": "npm publish --access public",
    "release": "n8n-node release",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "scripts/device-code-bootstrap.mjs",
    "scripts/n8n-data-tables.mjs"
  ],
  "dependencies": {
    "@n8n/ai-node-sdk": "^0.17.2",
    "@openai/codex": "0.145.0",
    "@openai/codex-sdk": "0.145.0",
    "n8nac": "2.4.1"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/ProDexAuthApi.credentials.js",
      "dist/credentials/ProDexN8nApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ProDex/ProDex.node.js",
      "dist/nodes/ProDexChatModel/ProDexChatModel.node.js",
      "dist/nodes/ProDexSetup/ProDexSetup.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.36.2",
    "@types/node": "^24.5.2",
    "eslint": "9.29.0",
    "n8n-workflow": "^2.13.1",
    "prettier": "3.6.2",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
